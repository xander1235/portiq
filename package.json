{
  "name": "portiq",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "dev:nix": "env -u ELECTRON_RUN_AS_NODE concurrently \"vite\" \"electron .\"",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "package": "vite build && electron-builder build --mac"
  },
  "description": "Portiq - The modern AI-powered API client",
  "author": "Portiq Contributors",
  "build": {
    "appId": "com.portiq.app",
    "productName": "Portiq",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "src/assets/logo.png"
    },
    "win": {
      "icon": "src/assets/logo.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "linux": {
      "icon": "src/assets/logo.png"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lint": "^6.9.4",
    "@codemirror/search": "^6.6.0",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@uiw/codemirror-theme-vscode": "^4.25.4",
    "@uiw/react-codemirror": "^4.25.4",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "idb-keyval": "^6.2.2",
    "libsodium-wrappers": "^0.8.2",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0"
  }
}
