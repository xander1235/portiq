{
  "name": "portiq",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "dev:nix": "env -u ELECTRON_RUN_AS_NODE concurrently \"vite\" \"electron .\"",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vite build && electron-builder build --publish never",
    "package:desktop": "vite build && electron-builder build --mac --win --linux --publish never",
    "package:mac": "vite build && electron-builder build --mac dmg zip --publish never",
    "package:win": "vite build && electron-builder build --win nsis portable --publish never",
    "package:linux": "vite build && electron-builder build --linux AppImage deb rpm --publish never",
    "package:release": "vite build && electron-builder build --publish never"
  },
  "description": "Portiq - The modern AI-powered API client",
  "repository": {
    "type": "git",
    "url": "https://github.com/xander1235/portiq.git"
  },
  "author": {
    "name": "Veerender Rathod",
    "email": "techie25vr@gmail.com"
  },
  "build": {
    "appId": "com.portiq.app",
    "productName": "Portiq",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "src/assets/logo.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "src/assets/logo.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "linux": {
      "icon": "src/assets/logo.png",
      "category": "Development",
      "maintainer": "Veerender Rathod <techie25vr@gmail.com>",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lint": "^6.9.4",
    "@codemirror/search": "^6.6.0",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.3.2",
    "@uiw/codemirror-theme-vscode": "^4.25.11",
    "@uiw/react-codemirror": "^4.25.11",
    "@xenova/transformers": "^2.17.2",
    "@xyflow/react": "^12.11.2",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "fuse.js": "^7.1.0",
    "idb-keyval": "^6.2.2",
    "libsodium-wrappers": "^0.8.2",
    "lucide-react": "^1.24.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dagre": "^0.7.54",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.4",
    "@electron/rebuild": "^4.2.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "eslint-plugin-react": {
      "eslint": "$eslint"
    }
  }
}
